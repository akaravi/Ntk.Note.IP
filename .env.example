# IPNote.ir — local development environment (copy to .env and adjust)
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Web API (standalone run without Aspire) — ports 5340-5349 map in scripts/local-dev-ports.ps1
ASPNETCORE_URLS=https://localhost:5341;http://localhost:5340

# Connection string (SQLite default; Aspire injects at runtime)
ConnectionStrings__CleanArchitectureDb=Data Source=CleanArchitectureDb.db

# Angular dev server (Aspire sets PORT=5342)
PORT=5342

# Optional: Azure Key Vault (production)
# AZURE_KEY_VAULT_ENDPOINT=https://your-vault.vault.azure.net/
