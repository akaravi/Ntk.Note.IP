{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "GeoIp": {
    "Provider": "MaxMind"
  },
  "IpLookup": {
    "Provider": "IpApi"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://ipnote.ir",
      "https://www.ipnote.ir",
      "https://noteip.ir",
      "https://www.noteip.ir"
    ]
  },
  "Jwt": {
    "BearerTokenExpirationHours": 24
  },
  "RateLimiting": {
    "GuestPermitLimit": 60,
    "GuestWindowMinutes": 1,
    "AuthPermitLimit": 10,
    "AuthWindowMinutes": 5
  },
  "OpenTelemetry": {
    "EnablePrometheusEndpoint": false
  }
}
